
<mujoco model="anchoring_workspace_scene">
<visual>
        <scale contactheight="0.05" contactwidth="0.01"/>
    </visual>
  <option cone="elliptic" noslip_iterations="5" integrator="implicit"/>
  <option timestep="0.0005" gravity="0 0 0"/>

  <asset>

    <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="32"/>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
  </asset>

  <include file="../J_snake_robot.xml"/>


  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="5 5 .05" type="plane" material="grid" group="2"/>
    <!-- fully enclosed equipment bay slot: 8.0cm center-to-center (6.0cm inner gap x),
         20cm inner depth (y), representative of satellite equipment panel channels -->
    <body name="Wall1" pos="0.040 0 0">
        <geom name="Wall_1" type="box" pos="0 0 0.5" size="0.01 0.11 0.5" contype="1" conaffinity="2" group="2" rgba="0.8 0.5 0.2 0.2"/>
    </body>

    <body name="Wall2" pos="-0.040 0 0">
        <geom name="Wall_2" type="box" pos="0 0 0.5" size="0.01 0.11 0.5" contype="1" conaffinity="2" group="2" rgba="0.8 0.5 0.2 0.2"/>
    </body>

    <body name="Wall3" pos="0 0.075 0">
        <geom name="Wall_3" type="box" pos="0 0 0.5" size="0.050 0.01 0.5" contype="1" conaffinity="2" group="2" rgba="0.8 0.5 0.2 0.2"/>
    </body>

    <body name="Wall4" pos="0 -0.02 0">
        <geom name="Wall_4" type="box" pos="0 0 0.5" size="0.050 0.01 0.5" contype="1" conaffinity="2" group="2" rgba="0.8 0.5 0.2 0.2"/>
    </body>
  </worldbody>
  </mujoco>
